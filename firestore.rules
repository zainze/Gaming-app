rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'zainzeb333@gmail.com' ||
        request.auth.uid == '8tF6rZeyoQc3L4Pukp8GsWpFHFi2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'role']) 
        && data.uid == request.auth.uid 
        && data.balance is number 
        && data.role in ['user', 'admin'];
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.amount is number
        && data.type in ['deposit', 'withdraw', 'wager', 'win', 'referral', 'bonus', 'penalty']
        && data.status in ['pending', 'completed', 'cancelled', 'failed']
        && data.createdAt is string;
    }

    function isValidBanner(data) {
      return data.keys().hasAll(['imageUrl', 'active'])
        && data.imageUrl is string && data.imageUrl.size() <= 500
        && data.active is bool;
    }

    // --- Collections ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isOwner(adminId) && !exists(/databases/$(database)/documents/system/admin_check);
      allow update, delete: if false;
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /system/admin_check {
      allow read: if true;
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/system/admin_check);
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && (
        (incoming().role == 'user') || 
        (!exists(/databases/$(database)/documents/system/admin_check)) ||
        (get(/databases/$(database)/documents/system/admin_check).data.first_admin == request.auth.uid)
      );
      // Owner can update their own doc
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'balance', 'lastActive', 'withdrawDetails', 'language', 'favorites', 'referredBy', 'lastBonusClaimed', 'doubleRewardsUntil', 'winStreak', 'lastCycleReset', 'rewardMultiplier'])
      );
      // Referred user (request.auth.uid) can increment referrer (userId) balance
      // provided they also create a referral record in the same batch
      allow update: if isSignedIn() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['balance'])
        && incoming().balance == (existing().balance + (get(/databases/$(database)/documents/system/config).data.referralReward))
        && existsAfter(/databases/$(database)/documents/referrals/$(request.auth.uid + '_' + userId));
      
      // Admin bypass
      allow update: if isAdmin();
    }

    match /invite_codes/{code} {
      allow read: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /transactions/{txId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && (
        isAdmin() ||
        isValidTransaction(incoming()) || 
        // Allow creating referral transaction if creating referral record
        (incoming().type == 'referral' && existsAfter(/databases/$(database)/documents/referrals/$(request.auth.uid + '_' + incoming().userId)))
      );
      allow update: if isAdmin(); 
      allow delete: if false;
    }

    match /promo_codes/{code} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isSignedIn() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['usedBy'])
        && incoming().usedBy.size() == (existing().get('usedBy', []).size() + 1)
        && incoming().usedBy.hasAll(existing().get('usedBy', []))
        && incoming().usedBy.hasAll([request.auth.uid]);
      allow delete: if false;
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn(); // Allow creating notification for referrer
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /referrals/{refId} {
      allow get: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() 
        && incoming().referredId == request.auth.uid 
        && incoming().rewardAmount == (get(/databases/$(database)/documents/system/config).data.referralReward)
        && refId == (request.auth.uid + '_' + incoming().referrerId); // Deterministic ID to prevent double dipping
      allow update, delete: if false;
    }
  }
}
